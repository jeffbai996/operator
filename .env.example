# Operator configuration — copy to `.env` (all optional; sensible defaults).

# ── Server ───────────────────────────────────────────────────────────────
OPERATOR_HOST=127.0.0.1
OPERATOR_PORT=5005
# OPERATOR_DEBUG=1

# ── Browser (the Chrome the agent drives) ─────────────────────────────────
OPERATOR_CHROME_PORT=9222
# OPERATOR_CHROME_BIN=/path/to/chrome      # auto-detected if unset
# OPERATOR_CHROME_PROFILE=~/.operator/chrome-profile
OPERATOR_VIEWPORT=1280,800

# ── Agent runtime ─────────────────────────────────────────────────────────
# PRIMARY (recommended): bring your own logged-in CLI subscription — no metered
# API spend. Install + sign in once; Operator shells out to it.
#   Claude:  install the `claude` CLI, run `claude login`   (creds in ~/.claude)
#   GPT:     install the `codex` CLI, sign in               (creds in ~/.codex)
# CLAUDE_CONFIG_DIR=~/.claude
# CODEX_HOME=~/.codex
#
# FALLBACK (metered, can get expensive — every step is a screenshot): set an API
# key instead of using a logged-in CLI. Driving a browser via the API burns a lot
# of tokens, so the subscription/CLI path above is strongly preferred.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
